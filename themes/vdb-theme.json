    "terminal.ansiWhite": "#bcb9b2",
    "terminal.ansiBrightWhite": "#d4d1ca",
    "terminal.ansiRed": "#c0392b",
    "terminal.ansiBrightRed": "#e74c3c",
    "terminal.ansiGreen": "#7a9e5e",
