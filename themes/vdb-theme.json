    "peekViewResult.background": "#0c0c0c",
    "peekViewResult.fileForeground": "#bcb9b2",
    "peekViewResult.lineForeground": "#6e6b65",
    "peekViewResult.matchHighlightBackground": "#fac11830",
    "peekViewResult.selectionBackground": "#1e1c18",
    "peekViewResult.selectionForeground": "#fac118",
    "peekViewTitle.background": "#0c0c0c",
    "peekViewTitleDescription.foreground": "#6e6b65",
    "peekViewTitleLabel.foreground": "#bcb9b2",

    "merge.currentHeaderBackground": "#7a9e5e30",
    "merge.currentContentBackground": "#7a9e5e10",
    "merge.incomingHeaderBackground": "#5a7a9e30",
    "merge.incomingContentBackground": "#5a7a9e10"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#4a4845", "fontStyle": "italic" }
    },
    {
      "name": "Doc Comments",
      "scope": ["comment.block.documentation"],
      "settings": { "foreground": "#5a5855", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "storage.modifier"
      ],
      "settings": { "foreground": "#c39301" }
    },
    {
      "name": "Storage Types",
      "scope": ["storage.type"],
      "settings": { "foreground": "#c39301" }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "entity.other.inherited-class",
        "support.type",
        "support.class"
      ],
      "settings": { "foreground": "#c39301" }
    },
    {
      "name": "Built-in Types",
      "scope": ["support.type.primitive", "keyword.type"],
      "settings": { "foreground": "#c39301" }
    },
    {
      "name": "Interfaces",
      "scope": ["entity.name.type.interface"],
      "settings": { "foreground": "#d4a820", "fontStyle": "italic" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": { "foreground": "#fac118" }
    },
    {
      "name": "Built-in Functions",
      "scope": ["support.function.builtin"],
      "settings": { "foreground": "#c39301" }
    },
    {
      "name": "Constructors",
      "scope": ["entity.name.function.constructor"],
      "settings": { "foreground": "#c39301" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#bcb9b2" }
    },
    {
      "name": "Special Variables (this, self)",
      "scope": ["variable.language"],
      "settings": { "foreground": "#fac118", "fontStyle": "italic" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#bcb9b2" }
    },
    {
      "name": "Properties",
      "scope": ["variable.other.property", "support.type.property-name"],
      "settings": { "foreground": "#bcb9b2" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted"],
      "settings": { "foreground": "#8a9e6a" }
    },
    {
      "name": "String Escapes",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#c39301" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#fac118" }
    },
    {
      "name": "Booleans & Constants",
      "scope": ["constant.language", "constant.other"],
      "settings": { "foreground": "#fac118" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#bcb9b2" }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": { "foreground": "#6e6b65" }
    },
    {
      "name": "Brackets",
      "scope": ["punctuation.definition.bracket", "meta.brace"],
      "settings": { "foreground": "#8a8780" }
    },
    {
      "name": "Tags (HTML/XML)",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#c39301" }
    },
    {
      "name": "Tag Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#fac118" }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#bcb9b2" }
    },
    {
      "name": "CSS Values",
      "scope": ["support.constant.property-value.css"],
      "settings": { "foreground": "#8a9e6a" }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": { "foreground": "#fac118" }
    },
    {
      "name": "Preprocessor / Macros",
      "scope": ["meta.preprocessor", "keyword.control.directive"],
      "settings": { "foreground": "#c39301" }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#c39301" }
    },
    {
      "name": "Namespace / Module",
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": { "foreground": "#bcb9b2" }
    },
    {
      "name": "Markdown Headings",
      "scope": ["markup.heading"],
      "settings": { "foreground": "#fac118", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#fac118", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#fac118", "fontStyle": "italic" }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#8a9e6a" }
    },
    {
      "name": "Markdown Links",
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#c39301" }
    },
    {
      "name": "Invalid",
      "scope": ["invalid"],
      "settings": { "foreground": "#e74c3c" }
    }
  ]
}
